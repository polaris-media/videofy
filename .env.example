### REQUIRED: Fill in OPENAI_API_KEY. ElevenLabs is optional because local TTS is supported on macOS.

OPENAI_API_KEY=
ELEVENLABS_API_KEY=

### OPTIONAL: Enable free local Norwegian narration on macOS when ElevenLabs is not configured.
LOCAL_TTS_ENABLED=false
LOCAL_TTS_VOICE=Nora
LOCAL_TTS_RATE=145

### OPTIONAL: Reuters fetcher is only shown in CMS when all Reuters values below are set.
REUTERS_CLIENT_ID=
REUTERS_CLIENT_SECRET=
REUTERS_AUDIENCE=
REUTERS_GRANT_TYPE=
REUTERS_SCOPE=

### OPTIONAL: AP fetcher is only shown in CMS when AP_API_KEY is set.
AP_API_KEY=

### OPTIONAL: Polaris-artikkel fetcher is only shown in CMS when both values below are set.
CAPI_USERNAME=
CAPI_PASSWORD=

### OPTIONAL: Hotspot model inference (default model is public and works without a token).
HOTSPOT_MODEL_ID=sch-ai/detr-hotspot

### Leave the following values as they are for local development. You can change them if you want to deploy the application to a different environment.
APP_BASE_URL=http://127.0.0.1:8001
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
PROJECTS_ROOT=projects
CONFIG_ROOT=brands

MINIMAL_DATA_API_URL=http://127.0.0.1:8001
NEXT_PUBLIC_CMS_BASE_URL=http://127.0.0.1:3000
MINIMAL_FILE_BASE_URL=http://127.0.0.1:8001
MINIMAL_PREWARM_REMOTION_BUNDLE=true
